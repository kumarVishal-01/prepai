# Gemini API Credentials (optional: you can also set this directly in the Settings page in the UI)
GEMINI_API_KEY=your_gemini_api_key_here

# Backend server Port
PORT=5000

# MongoDB URI (MongoDB Atlas or local)
MONGODB_URI=mongodb+srv://<db_user>:<db_password>@cluster.mongodb.net/PlacementInterview?retryWrites=true&w=majority


# JWT Secret for signing cookies/tokens
JWT_SECRET=your_jwt_secret_here

# Cloudinary Credentials (for document uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Frontend API base URL (optional: if hosting frontend separately, set this to your backend production URL)
VITE_API_BASE_URL=https://your-backend-api.onrender.com

# CORS Allowed Origins (optional: comma-separated list of origins allowed to connect to this API)
FRONTEND_URL=https://your-frontend-app.vercel.app,http://localhost:5173
